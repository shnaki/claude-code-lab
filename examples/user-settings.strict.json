{
  "permissions": {
    "defaultMode": "plan",
    "disableBypassPermissionsMode": false,
    "allow": [
      "Bash(git status)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(npm run lint)",
      "Bash(npm run lint:*)",
      "Bash(npm run test)",
      "Bash(npm run test:*)",
      "Bash(npm run typecheck)",
      "Bash(npm run build)",
      "Read(./src/**)",
      "Read(./tests/**)",
      "Read(./docs/**)",
      "Read(./package.json)",
      "Read(./tsconfig.json)",
      "Read(./.eslintrc.*)",
      "Read(./README.md)"
    ],
    "ask": [],
    "deny": [
      "Read(.env)",
      "Read(.env.*)",
      "Read(**/.env)",
      "Read(**/.env.*)",
      "Read(**/secrets/**)",
      "Read(**/*.pem)",
      "Read(**/*.key)",
      "Read(**/*.p12)",
      "Read(**/*.pfx)",
      "Read(**/*.crt)",
      "Read(**/*.cer)",
      "Read(**/id_rsa)",
      "Read(**/id_rsa.pub)",
      "Read(**/id_ed25519)",
      "Read(**/id_ed25519.pub)",
      "Read(**/id_ecdsa)",
      "Read(~/.ssh/**)",
      "Read(~/.aws/**)",
      "Read(~/.config/gcloud/**)",
      "Read(~/.kube/**)",
      "Read(**/credentials)",
      "Read(**/credentials.json)",
      "Read(**/service-account*.json)",
      "Edit(.env)",
      "Edit(.env.*)",
      "Edit(**/.env)",
      "Edit(**/.env.*)",
      "Edit(**/secrets/**)",
      "Edit(~/.ssh/**)",
      "Edit(~/.aws/**)",
      "Edit(~/.kube/**)",
      "WebFetch(*)",
      "Bash(curl:*)",
      "Bash(wget:*)",
      "Bash(Invoke-WebRequest:*)",
      "Bash(Invoke-RestMethod:*)",
      "Bash(iwr:*)",
      "Bash(irm:*)",
      "Bash(scp:*)",
      "Bash(sftp:*)",
      "Bash(rsync:*)",
      "Bash(nc:*)",
      "Bash(ncat:*)",
      "Bash(nmap:*)",
      "Bash(ssh:*)",
      "Bash(rm:*)",
      "Bash(Remove-Item:*)",
      "Bash(del:*)",
      "Bash(rd:*)",
      "Bash(format:*)",
      "Bash(mkfs:*)",
      "Bash(dd:*)",
      "Bash(shred:*)",
      "Bash(git push:*)",
      "Bash(git reset:*)",
      "Bash(git clean:*)",
      "Bash(git rebase:*)",
      "Bash(git stash drop:*)",
      "Bash(sudo:*)",
      "Bash(su:*)",
      "Bash(runas:*)",
      "Bash(Start-Process:*)",
      "Bash(chmod:*)",
      "Bash(chown:*)",
      "Bash(icacls:*)",
      "Bash(takeown:*)",
      "Bash(npm publish:*)",
      "Bash(npm install -g:*)",
      "Bash(npx:*)",
      "Bash(pip install:*)",
      "Bash(pip3 install:*)",
      "Bash(pip install -e:*)",
      "Bash(docker push:*)",
      "Bash(docker run:*)",
      "Bash(kubectl apply:*)",
      "Bash(kubectl delete:*)",
      "Bash(helm install:*)",
      "Bash(helm upgrade:*)",
      "Bash(terraform apply:*)",
      "Bash(terraform destroy:*)",
      "Bash(aws:*)",
      "Bash(gcloud:*)",
      "Bash(az:*)"
    ]
  },
  "enableAllProjectMcpServers": false,
  "enabledMcpjsonServers": [],
  "cleanupPeriodDays": 3,
  "includeCoAuthoredBy": false,
  "env": {
    "CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC": "1",
    "DISABLE_AUTOUPDATER": "1",
    "DISABLE_ERROR_REPORTING": "1",
    "DISABLE_TELEMETRY": "1",
    "CLAUDE_CODE_ENABLE_TELEMETRY": "1",
    "OTEL_METRICS_EXPORTER": "otlp",
    "OTEL_LOGS_EXPORTER": "otlp",
    "OTEL_EXPORTER_OTLP_ENDPOINT": "https://otel-collector.example.internal",
    "OTEL_SERVICE_NAME": "claude-code"
  }
}
