{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",

  "permissions": {
    "disableBypassPermissionsMode": "disable",

    "allow": [
      "Bash(git status)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git branch:*)",
      "Bash(git fetch:*)",
      "Bash(git pull:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git checkout:*)",
      "Bash(ls:*)",
      "Bash(Get-ChildItem:*)",
      "Bash(npm run lint:*)",
      "Bash(npm run build:*)",
      "Bash(npm run test:*)",
      "Bash(npm test:*)",
      "Bash(node --version)",
      "Bash(python --version)",
      "Bash(python3 --version)"
    ],

    "deny": [
      "Read(.env)",
      "Read(.env.*)",
      "Read(**/.env)",
      "Read(**/.env.*)",
      "Read(**/secrets/**)",
      "Read(**/*.pem)",
      "Read(**/*.key)",
      "Read(**/*.p12)",
      "Read(**/*.pfx)",
      "Read(**/id_rsa)",
      "Read(**/id_ed25519)",
      "Read(**/id_ecdsa)",
      "Read(~/.ssh/**)",
      "Read(~/.aws/**)",
      "Read(~/.config/gcloud/**)",
      "Read(~/.kube/**)",
      "Read(**/credentials)",
      "Read(**/credentials.json)",
      "Read(**/service-account*.json)",
      "Edit(.env)",
      "Edit(.env.*)",
      "Edit(**/.env)",
      "Edit(**/secrets/**)",
      "Edit(~/.ssh/**)",
      "Edit(~/.aws/**)",
      "Bash(curl:*)",
      "Bash(wget:*)",
      "Bash(Invoke-WebRequest:*)",
      "Bash(Invoke-RestMethod:*)",
      "Bash(iwr:*)",
      "Bash(irm:*)",
      "Bash(scp:*)",
      "Bash(sftp:*)",
      "Bash(nc:*)",
      "Bash(ncat:*)",
      "Bash(rm -rf:*)",
      "Bash(Remove-Item -Recurse:*)",
      "Bash(Remove-Item -Force:*)",
      "Bash(git push --force:*)",
      "Bash(git push -f:*)",
      "Bash(git reset --hard:*)",
      "Bash(git clean:*)",
      "Bash(sudo:*)",
      "Bash(su:*)",
      "Bash(runas:*)",
      "Bash(Start-Process:*)",
      "Bash(npm publish:*)",
      "Bash(docker push:*)",
      "Bash(kubectl delete:*)",
      "Bash(terraform destroy:*)",
      "Bash(terraform apply:*)"
    ]
  },

  "allowManagedPermissionRulesOnly": true,

  "forceLoginMethod": "claudeai",
  "forceLoginOrgUUID": "<YOUR-ORG-UUID>",

  "requiredMinimumVersion": "2.1.38",

  "forceRemoteSettingsRefresh": true,

  "enableAllProjectMcpServers": false,
  "enabledMcpjsonServers": [],

  "cleanupPeriodDays": 7,
  "autoUpdatesChannel": "stable",

  "env": {
    "CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC": "1",
    "DISABLE_AUTOUPDATER": "1",
    "DISABLE_ERROR_REPORTING": "1",
    "DISABLE_TELEMETRY": "1",
    "CLAUDE_CODE_ENABLE_TELEMETRY": "1",
    "OTEL_METRICS_EXPORTER": "otlp",
    "OTEL_LOGS_EXPORTER": "otlp",
    "OTEL_EXPORTER_OTLP_ENDPOINT": "https://otel-collector.example.internal",
    "OTEL_SERVICE_NAME": "claude-code"
  }
}
